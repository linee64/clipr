# Copy to backend/.env for local dev, or set these as Railway service variables.

# --- Supabase (storage for clips / audio / rendered videos) ---
# Use the SERVICE ROLE key (Settings > API), not the anon key, so uploads bypass RLS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_BUCKET=clipr-videos

# --- Google Gemini (idea + storyboard generation) ---
GEMINI_API_KEY=your_gemini_api_key

# --- Pexels (stock-video search to fill a scene's "what to film") ---
# Free API key from https://www.pexels.com/api/ . Missing -> the stock-search
# button still shows but returns a clear "not configured" message.
PEXELS_API_KEY=your_pexels_api_key

# --- ElevenLabs (AI voiceover for b-roll renders) ---
# API key from https://elevenlabs.io (Profile > API Keys). Missing -> the voice
# routes return a clear "not configured" message and renders just skip voiceover.
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- CORS: comma-separated frontend origins allowed to call this API ---
# Set to your deployed frontend URL (e.g. the Vercel domain).
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# --- X / Twitter auto-posting (OAuth 2.0 Authorization Code + PKCE) ---
# Create an X app (developer.x.com) with "Read and Write" permission, attached to
# a Project, OAuth 2.0 enabled as a *Confidential client* (Web App) so it has a
# client secret. TWITTER_CALLBACK_URL must EXACTLY match the redirect URI you
# registered in the portal — point it at the frontend passthrough route.
TWITTER_CLIENT_ID=your_oauth2_client_id
TWITTER_CLIENT_SECRET=your_oauth2_client_secret
TWITTER_CALLBACK_URL=https://your-frontend-domain/api/auth/twitter/callback
# Where the backend sends the browser after a successful connect (your dashboard).
TWITTER_POST_CONNECT_URL=https://your-frontend-domain/dashboard

# --- LinkedIn connect + auto-posting (OAuth 2.0 Authorization Code) ---
# Create an app at https://www.linkedin.com/developers/apps and request the products
# "Sign In with LinkedIn using OpenID Connect" (openid, profile) and "Share on
# LinkedIn" (w_member_social). LINKEDIN_CALLBACK_URL must EXACTLY match an Authorized
# redirect URL in the app's Auth tab — point it at the frontend passthrough route.
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=https://your-frontend-domain/api/auth/linkedin/callback
# Where the backend sends the browser after a successful connect (your dashboard).
LINKEDIN_POST_CONNECT_URL=https://your-frontend-domain/dashboard
# Versioned REST API header (YYYYMM). LinkedIn sunsets versions after ~1 year — if a
# call 426s with NONEXISTENT_VERSION, bump this to a Supported version from the portal.
LINKEDIN_API_VERSION=202601

# PORT is provided by Railway automatically; only set it for local docker runs.
# PORT=8000
